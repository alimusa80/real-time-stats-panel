{
    "name": "alimusa/real-time-stats-panel",
    "description": "Production-ready real-time dashboard metrics plugin for FilamentPHP with Laravel Echo and Pusher-compatible broadcasting.",
    "type": "library",
    "license": "MIT",
    "homepage": "https://www.alimusa.so/",
    "keywords": [
        "admin-panel",
        "alimusa",
        "dashboard",
        "filament",
        "filamentphp",
        "laravel",
        "livewire",
        "plugin",
        "pusher",
        "realtime",
        "soketi",
        "websockets"
    ],
    "authors": [
        {
            "name": "Ali Musa",
            "homepage": "https://www.alimusa.so/"
        }
    ],
    "require": {
        "php": "^8.2",
        "filament/filament": "^4.3 || ^5.0",
        "illuminate/auth": "^11.0 || ^12.0",
        "illuminate/broadcasting": "^11.0 || ^12.0",
        "illuminate/cache": "^11.0 || ^12.0",
        "illuminate/contracts": "^11.0 || ^12.0",
        "illuminate/events": "^11.0 || ^12.0",
        "illuminate/support": "^11.0 || ^12.0",
        "spatie/laravel-package-tools": "^1.16"
    },
    "require-dev": {
        "orchestra/testbench": "^9.0 || ^10.0",
        "phpunit/phpunit": "^10.5 || ^11.0"
    },
    "autoload": {
        "psr-4": {
            "Alimusa\\RealTimeStatsPanel\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Alimusa\\RealTimeStatsPanel\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Alimusa\\RealTimeStatsPanel\\RealTimeStatsPanelServiceProvider"
            ]
        },
        "branch-alias": {
            "dev-main": "1.x-dev"
        }
    },
    "support": {
        "docs": "https://www.alimusa.so/",
        "issues": "https://github.com/alimusa80/real-time-stats-panel/issues",
        "source": "https://github.com/alimusa80/real-time-stats-panel"
    },
    "scripts": {
        "test": "phpunit",
        "test:coverage": "phpunit --coverage-text"
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
